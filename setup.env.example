# =============================================================================
# Setup Environment File
# =============================================================================
# Copy this to setup.env and fill in the values.
# Both setup.sh and server-setup.sh will read from setup.env to skip prompts
# for any values that are already set.
#
#   cp setup.env.example setup.env
#   $EDITOR setup.env
#   ./setup.sh
#
# Leave a value blank to be prompted for it interactively.
# =============================================================================

# -- setup.sh values (local machine) -----------------------------------------

SERVER_IP=
SSH_KEY=                    # Full public key string (ssh-ed25519 AAAA...)
ORIGIN_CERT_PATH=           # Path to Cloudflare Origin CA cert .pem
ORIGIN_KEY_PATH=            # Path to Cloudflare Origin CA key .pem
GITHUB_PAT=                 # GitHub Personal Access Token

# -- server-setup.sh values (runs on server) ---------------------------------

DOMAIN=
ALLOWED_DOMAIN=             # Defaults to DOMAIN if blank
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_TOKEN=               # Same as GITHUB_PAT above
GITHUB_WEBHOOK_SECRET=      # Leave blank to auto-generate
SSH_PUBKEY=                 # SSH public key for containers
ALLOWED_REPOS=              # Comma-separated owner/repo, blank for all
VERTEX_REPOS=               # Comma-separated owner/repo, blank for none
GIT_EMAIL=                  # Git commit signing email
