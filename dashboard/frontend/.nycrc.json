  "exclude": ["src/**/*.d.ts", "src/components/ui/**", "src/components/VoiceInput.tsx", "src/components/DiffViewer.tsx", "src/components/LogViewer.tsx", "src/components/TaskChat.tsx", "src/components/BranchCombobox.tsx", "src/components/MetricChart.tsx", "src/hooks/use-mobile.ts", "src/pages/Webhooks.tsx", "src/pages/Autoresearch.tsx", "src/pages/AutoresearchDetail.tsx"],
  "check-coverage": true,
  "branches": 70,
  "lines": 70,
  "functions": 70,
  "statements": 70,
  "reporter": ["text", "text-summary", "html"],
  "report-dir": "coverage"
}
